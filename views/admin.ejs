<%- include('partials/header') %>

<!-- ADMIN HERO -->
<div style="background:linear-gradient(135deg,#0F1A2E 0%,#1A2B4C 60%,#0F1A2E 100%);padding:calc(var(--header-h) + var(--space-10)) 0 var(--space-10);position:relative;overflow:hidden">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="container" style="position:relative;z-index:2">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4)">
      <div>
        <div style="display:flex;align-items:center;gap:var(--space-3);margin-bottom:var(--space-3)">
          <div style="width:40px;height:40px;background:rgba(0,168,107,.15);border:1px solid rgba(0,168,107,.3);border-radius:var(--radius-lg);display:flex;align-items:center;justify-content:center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00A86B" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <span style="font-size:var(--text-sm);font-weight:700;color:#00A86B;letter-spacing:.08em;text-transform:uppercase">Admin Panel</span>
        </div>
        <h1 style="font-family:var(--font-serif);font-size:clamp(1.6rem,3vw,2.4rem);font-weight:800;color:#F1F5FF;letter-spacing:-.02em;margin:0">Distributor Management</h1>
        <p style="color:rgba(241,245,255,.5);font-size:var(--text-sm);margin-top:var(--space-2)">Review, approve or reject distributor registration requests</p>
      </div>
      <!-- Stats chips -->
      <div style="display:flex;gap:var(--space-3);flex-wrap:wrap">
        <div class="admin-stat-chip">
          <span class="admin-stat-val"><%= distributors.length %></span>
          <span class="admin-stat-lbl">Total Requests</span>
        </div>
        <div class="admin-stat-chip admin-stat-chip-yellow">
          <span class="admin-stat-val"><%= distributors.filter(d=>d.status==='pending').length %></span>
          <span class="admin-stat-lbl">Pending</span>
        </div>
        <div class="admin-stat-chip admin-stat-chip-green">
          <span class="admin-stat-val"><%= distributors.filter(d=>d.status==='approved').length %></span>
          <span class="admin-stat-lbl">Approved</span>
        </div>
        <div class="admin-stat-chip admin-stat-chip-red">
          <span class="admin-stat-val"><%= distributors.filter(d=>d.status==='rejected').length %></span>
          <span class="admin-stat-lbl">Rejected</span>
        </div>
      </div>
    </div>
  </div>
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none"><path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="#F8FAFC"/></svg>
  </div>
</div>

<section style="padding:var(--space-10) 0 var(--space-16);background:var(--color-surface)">
  <div class="container">

    <!-- FLASH MESSAGES -->
    <% if(flash==='approved' && genDist){ %>
    <!-- Credential Card -->
    <div class="admin-cred-card">
      <div class="admin-cred-header">
        <div class="admin-cred-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div>
          <h3>✅ Distributor Approved!</h3>
          <p>Credentials have been generated for <strong><%= genDist.name %></strong>. Share these securely.</p>
        </div>
      </div>
      <div class="admin-cred-grid">
        <div class="admin-cred-field">
          <span class="admin-cred-label">Distributor Name</span>
          <span class="admin-cred-value"><%= genDist.name %></span>
        </div>
        <div class="admin-cred-field">
          <span class="admin-cred-label">Company</span>
          <span class="admin-cred-value"><%= genDist.company %></span>
        </div>
        <div class="admin-cred-field">
          <span class="admin-cred-label">🔑 Login ID (Phone)</span>
          <span class="admin-cred-value mono-val"><%= genDist.phone %></span>
        </div>
        <div class="admin-cred-field">
          <span class="admin-cred-label">🔒 Generated Password</span>
          <span class="admin-cred-value mono-val"><%= genDist.password %></span>
        </div>
        <div class="admin-cred-field">
          <span class="admin-cred-label">Product</span>
          <span class="admin-cred-value"><%= genDist.product %></span>
        </div>
        <div class="admin-cred-field">
          <span class="admin-cred-label">Approved On</span>
          <span class="admin-cred-value"><%= new Date(genDist.approvedAt).toLocaleString('en-IN') %></span>
        </div>
      </div>
      <div style="margin-top:var(--space-4);display:flex;gap:var(--space-3);flex-wrap:wrap">
        <a href="/distributor/<%= genDist.id %>" target="_blank" class="btn btn-primary" style="font-size:var(--text-sm)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Preview Distributor Portal
        </a>
        <button onclick="copyToClipboard('<%= genDist.phone %>', '<%= genDist.password %>')" class="btn btn-outline" style="font-size:var(--text-sm)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          Copy Credentials
        </button>
      </div>
    </div>
    <% } %>

    <% if(flash==='rejected'){ %>
    <div class="dist-alert dist-alert-error" style="margin-bottom:var(--space-6)">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      Distributor application has been rejected.
    </div>
    <% } %>
    <% if(flash==='deleted'){ %>
    <div class="dist-alert dist-alert-warning" style="margin-bottom:var(--space-6)">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
      Record deleted successfully.
    </div>
    <% } %>

    <!-- REQUESTS TABLE -->
    <div class="admin-table-card">
      <div class="admin-table-header">
        <h2>All Distributor Requests</h2>
        <div style="display:flex;gap:var(--space-3)">
          <select class="form-input" id="filter-status" style="padding:var(--space-2) var(--space-4);width:auto;font-size:var(--text-sm)" onchange="filterTable(this.value)">
            <option value="all">All Statuses</option>
            <option value="pending">Pending</option>
            <option value="approved">Approved</option>
            <option value="rejected">Rejected</option>
          </select>
        </div>
      </div>

      <% if(distributors.length === 0){ %>
      <div class="admin-empty">
        <div style="font-size:3rem;margin-bottom:var(--space-4)">📭</div>
        <h3>No Requests Yet</h3>
        <p>Distributor registration requests will appear here. Share the <a href="/buy" style="color:var(--color-accent)">Buy Product</a> page with potential distributors.</p>
      </div>
      <% } else { %>
      <div style="overflow-x:auto">
        <table class="admin-table" id="dist-table">
          <thead>
            <tr>
              <th>Applicant</th>
              <th>Phone (Login ID)</th>
              <th>Company</th>
              <th>Location</th>
              <th>Product</th>
              <th>Quantity</th>
              <th>Applied</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% distributors.slice().reverse().forEach(function(d){ %>
            <tr data-status="<%= d.status %>">
              <td>
                <div style="font-weight:600;color:var(--color-primary)"><%= d.name %></div>
                <div style="font-size:var(--text-xs);color:var(--color-text-muted)"><%= d.email %></div>
              </td>
              <td><span class="mono-chip"><%= d.phone %></span></td>
              <td><%= d.company %></td>
              <td style="font-size:var(--text-sm);color:var(--color-text-muted)"><%= d.location %></td>
              <td><span class="product-chip"><%= d.product %></span></td>
              <td style="font-size:var(--text-sm)"><%= d.quantity %></td>
              <td style="font-size:var(--text-xs);color:var(--color-text-muted)"><%= new Date(d.appliedAt).toLocaleDateString('en-IN') %></td>
              <td>
                <span class="status-badge status-<%= d.status %>">
                  <%= d.status === 'pending' ? '⏳ Pending' : d.status === 'approved' ? '✅ Approved' : '❌ Rejected' %>
                </span>
                <% if(d.status === 'approved'){ %>
                <div style="font-size:var(--text-xs);color:var(--color-text-muted);margin-top:4px">
                  Pass: <span class="mono-chip"><%= d.password %></span>
                </div>
                <% } %>
              </td>
              <td>
                <div class="admin-actions">
                  <% if(d.status === 'pending'){ %>
                  <form action="/admin/approve/<%= d.id %>" method="POST" style="display:inline">
                    <button type="submit" class="admin-btn admin-btn-approve" title="Approve">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                      Approve
                    </button>
                  </form>
                  <form action="/admin/reject/<%= d.id %>" method="POST" style="display:inline">
                    <button type="submit" class="admin-btn admin-btn-reject" title="Reject"
                      onclick="return confirm('Reject this application?')">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                      Reject
                    </button>
                  </form>
                  <% } %>
                  <% if(d.status === 'approved'){ %>
                  <a href="/distributor/<%= d.id %>" target="_blank" class="admin-btn admin-btn-view">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    View Portal
                  </a>
                  <% } %>
                  <form action="/admin/delete/<%= d.id %>" method="POST" style="display:inline">
                    <button type="submit" class="admin-btn admin-btn-delete" title="Delete"
                      onclick="return confirm('Permanently delete this record?')">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div><!-- /admin-table-card -->

  </div>
</section>

<script>
function filterTable(status){
  document.querySelectorAll('#dist-table tbody tr').forEach(function(row){
    row.style.display = (status==='all' || row.dataset.status===status) ? '' : 'none';
  });
}
function copyToClipboard(phone, password){
  const text = `Login ID: ${phone}\nPassword: ${password}`;
  navigator.clipboard.writeText(text).then(()=>alert('Credentials copied!'));
}
</script>

<%- include('partials/footer') %>
