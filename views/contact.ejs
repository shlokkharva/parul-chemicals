<%- include('partials/header') %>

<div style="background:var(--grad-hero);padding:calc(var(--header-h) + var(--space-16)) 0 var(--space-16);position:relative;overflow:hidden">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="container" style="position:relative;z-index:2;text-align:center">
    <span class="section-label" style="justify-content:center">Let's Connect</span>
    <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3.2rem);font-weight:800;color:#F1F5FF;letter-spacing:-.02em;margin-bottom:var(--space-5)">Let's Discuss<br/>Your Requirements</h1>
    <p style="font-size:var(--text-lg);color:var(--color-text-on-dark-muted);max-width:560px;margin:0 auto">
      Whether you need a TDS, custom synthesis quote, or regulatory documentation — our team responds within 24 hours.
    </p>
  </div>
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="#ffffff"/></svg>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="contact-wrap">
      <!-- Left info -->
      <div class="contact-info reveal">
        <span class="section-label">Contact Details</span>
        <h2 id="contact-title">Get in Touch</h2>
        <p>Reach us by phone, email or visit our office in Vadodara, Gujarat.</p>
        <div class="contact-detail-list">
          <div class="contact-detail">
            <div class="contact-icon-wrap">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00A86B" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            </div>
            <div class="contact-detail-text">
              <strong>Phone</strong>
              <span><a href="tel:+919427784082" style="color:inherit"><%= phone %></a></span>
            </div>
          </div>
          <div class="contact-detail">
            <div class="contact-icon-wrap">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00A86B" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="contact-detail-text">
              <strong>Email</strong>
              <span><a href="mailto:<%= email %>" style="color:inherit"><%= email %></a></span>
            </div>
          </div>
          <div class="contact-detail">
            <div class="contact-icon-wrap">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00A86B" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="contact-detail-text">
              <strong>Address</strong>
              <span><%- address.replace(',', ',<br/>') %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right form -->
      <div class="contact-form-wrap reveal reveal-delay-2">
        <% if(sent){ %>
        <div class="form-success active" role="alert">
          <div class="form-success-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div class="form-success-text">
            <strong>Message sent successfully!</strong>
            <span>Our team will respond within 24 business hours.</span>
          </div>
        </div>
        <div style="text-align:center;margin-top:var(--space-6)">
          <a href="/contact" class="btn btn-outline">Send Another Message</a>
        </div>
        <% } else { %>
        <form action="/contact" method="POST" id="contact-form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="contact-name">Full Name *</label>
              <input class="form-input" type="text" id="contact-name" name="name" placeholder="Dr. Jane Smith" required autocomplete="name"/>
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-email">Business Email *</label>
              <input class="form-input" type="email" id="contact-email" name="email" placeholder="jane@pharmalab.com" required autocomplete="email"/>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="contact-company">Company</label>
              <input class="form-input" type="text" id="contact-company" name="company" placeholder="PharmaLab Inc." autocomplete="organization"/>
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-product">Product Interest</label>
              <input class="form-input" type="text" id="contact-product" name="product" placeholder="TEC / FS CALCIVAL / DEP" value="<%= typeof query !== 'undefined' && query.product ? query.product : '' %>"/>
            </div>
          </div>
          <div class="form-group full">
            <label class="form-label" for="contact-message">Message *</label>
            <textarea class="form-textarea" id="contact-message" name="message" placeholder="Describe your application, required quantities, purity specifications..." required></textarea>
          </div>
          <div class="form-submit-wrap">
            <button type="submit" class="btn btn-primary form-btn" id="form-submit-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              Send Message
            </button>
          </div>
        </form>
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Map-like address block -->
<div class="stats-strip" style="padding:var(--space-12) 0">
  <div class="container" style="text-align:center">
    <p style="color:var(--color-text-on-dark-muted);font-size:var(--text-sm);margin-bottom:var(--space-3)">Our Office</p>
    <p style="color:#fff;font-size:var(--text-xl);font-weight:700"><%= address %></p>
    <a href="https://maps.google.com/?q=Ranjan+Society+2+Race+Course+Vadodara+Gujarat" target="_blank" class="btn btn-outline-light" style="margin-top:var(--space-5)">Open in Google Maps &rarr;</a>
  </div>
</div>

<%- include('partials/footer') %>
