<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <meta name="description" content="Parul Chemicals — Global Innovative Plasticizer Solutions for Pharmaceutical, Agrochemical, Food and Nutrition industries."/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
</head>
<body>

<header class="site-header" id="site-header" role="banner">
  <div class="header-inner">
    <a href="/" class="logo-wrap" aria-label="Parul Chemicals Home">
      <svg class="logo-mol" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="20" cy="20" r="4" fill="#00A86B"/>
        <circle cx="8"  cy="12" r="3" fill="#00A86B" opacity=".7"/>
        <circle cx="32" cy="12" r="3" fill="#00A86B" opacity=".7"/>
        <circle cx="8"  cy="28" r="3" fill="#00A86B" opacity=".7"/>
        <circle cx="32" cy="28" r="3" fill="#00A86B" opacity=".7"/>
        <line x1="20" y1="20" x2="8"  y2="12" stroke="#00A86B" stroke-width="1.5" opacity=".5"/>
        <line x1="20" y1="20" x2="32" y2="12" stroke="#00A86B" stroke-width="1.5" opacity=".5"/>
        <line x1="20" y1="20" x2="8"  y2="28" stroke="#00A86B" stroke-width="1.5" opacity=".5"/>
        <line x1="20" y1="20" x2="32" y2="28" stroke="#00A86B" stroke-width="1.5" opacity=".5"/>
      </svg>
      <div>
        <span class="logo-name"><%= siteName.toUpperCase() %></span>
        <span class="logo-tagline"><%= tagline %></span>
      </div>
    </a>

    <nav class="nav-links" role="navigation" aria-label="Main navigation">
      <% nav.forEach(function(item){ %>
        <a href="<%= item.href %>"
           class="nav-link<%= page === item.href.replace('/','') || (page==='home' && item.href==='/') ? ' nav-link-active' : '' %>">
          <%= item.label %>
        </a>
      <% }) %>
    </nav>
    <a href="/buy?tab=register" class="nav-cta nav-dist-btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
      Become a Distributor
    </a>

    <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile Nav -->
<div class="mobile-overlay" id="mobile-overlay"></div>
<nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
  <button class="mobile-close" id="mobile-close" aria-label="Close menu">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <div class="mobile-nav-links">
    <% nav.forEach(function(item){ %>
      <a href="<%= item.href %>" class="mobile-nav-link"><%= item.label %></a>
    <% }) %>
    <a href="/buy?tab=register" class="mobile-nav-link mobile-dist-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
      Become a Distributor
    </a>
  </div>
</nav>
