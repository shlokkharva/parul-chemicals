<%- include('partials/header') %>

<!-- PAGE HERO -->
<div class="page-hero">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="container" style="position:relative;z-index:2;text-align:center">
    <span class="section-label" style="justify-content:center">Distributor Portal</span>
    <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3rem);font-weight:800;color:#F1F5FF;letter-spacing:-.02em;margin-bottom:var(--space-4)">
      Buy Parul Chemicals Products
    </h1>
    <p style="color:var(--color-text-on-dark-muted);font-size:var(--text-lg);max-width:520px;margin:0 auto">
      Register as an authorized distributor or login with your approved credentials to place orders.
    </p>
  </div>
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="#ffffff"/></svg>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="buy-portal-wrap">

      <!-- ── TAB SWITCHER ── -->
      <div class="buy-tabs" role="tablist" aria-label="Portal sections">
        <a href="/buy?tab=register"
           class="buy-tab <%= tab==='register' ? 'buy-tab-active' : '' %>"
           role="tab" aria-selected="<%= tab==='register' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          Register as Distributor
        </a>
        <a href="/buy?tab=login"
           class="buy-tab <%= tab==='login' ? 'buy-tab-active' : '' %>"
           role="tab" aria-selected="<%= tab==='login' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
          Distributor Login
        </a>
      </div>

      <!-- ══════════════════════════════════════
           TAB 1 — REGISTER
      ══════════════════════════════════════ -->
      <% if(tab === 'register'){ %>
      <div class="buy-panel" role="tabpanel">

        <% if(success){ %>
        <!-- SUCCESS STATE -->
        <div class="dist-success-card">
          <div class="dist-success-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h2>Application Submitted!</h2>
          <p>Your distributor application has been received. Our admin team will review it within <strong>24–48 hours</strong>.</p>
          <div class="dist-success-steps">
            <div class="dist-step done">
              <div class="dist-step-dot"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
              <div><strong>Application Submitted</strong><span>Your form is received</span></div>
            </div>
            <div class="dist-step-line"></div>
            <div class="dist-step pending">
              <div class="dist-step-dot">2</div>
              <div><strong>Admin Review</strong><span>Within 24–48 hours</span></div>
            </div>
            <div class="dist-step-line"></div>
            <div class="dist-step pending">
              <div class="dist-step-dot">3</div>
              <div><strong>Credentials Issued</strong><span>Login ID + Password sent</span></div>
            </div>
            <div class="dist-step-line"></div>
            <div class="dist-step pending">
              <div class="dist-step-dot">4</div>
              <div><strong>Start Ordering</strong><span>Access the distributor portal</span></div>
            </div>
          </div>
          <p style="margin-top:var(--space-5);font-size:var(--text-sm);color:var(--color-text-muted)">Once approved, your Login ID will be your <strong>phone number</strong> and a password will be shared with you.</p>
          <a href="/buy?tab=register" class="btn btn-outline" style="margin-top:var(--space-4)">Register Another</a>
        </div>
        <% } else { %>

        <!-- Error alerts -->
        <% if(error === 'phone_exists'){ %>
        <div class="dist-alert dist-alert-error">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          A registration with this phone number already exists. Please use a different number or <a href="/buy?tab=login">login instead</a>.
        </div>
        <% } %>

        <!-- REGISTRATION FORM -->
        <div class="buy-split">
          <!-- Left: Info -->
          <div class="buy-info">
            <h2>Become an Authorized Distributor</h2>
            <p>Join our trusted network of distributors and get exclusive access to Parul Chemicals' full product range at competitive wholesale prices.</p>
            <div class="buy-perks">
              <% [
                {icon:'💰', text:'Competitive wholesale pricing'},
                {icon:'🚚', text:'Priority delivery & logistics support'},
                {icon:'📋', text:'Dedicated account manager'},
                {icon:'📄', text:'Access to full TDS & COA documents'},
                {icon:'🏅', text:'Authorized distributor certificate'},
                {icon:'📞', text:'24/7 technical support'}
              ].forEach(function(p){ %>
              <div class="buy-perk">
                <span class="buy-perk-icon"><%= p.icon %></span>
                <span><%= p.text %></span>
              </div>
              <% }) %>
            </div>
            <div style="margin-top:var(--space-6);padding:var(--space-4);background:var(--color-accent-muted);border-radius:var(--radius-xl);border-left:3px solid var(--color-accent)">
              <p style="font-size:var(--text-sm);color:var(--color-text);margin:0">
                <strong>🔐 After approval:</strong> Your <strong>Login ID = Phone Number</strong>. A secure password will be generated and shared with you.
              </p>
            </div>
          </div>

          <!-- Right: Form -->
          <div class="buy-form-wrap">
            <form action="/buy/register" method="POST" id="dist-reg-form" novalidate>
              <div class="form-section-label">Personal Information</div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="dist-name">Full Name *</label>
                  <input class="form-input" type="text" id="dist-name" name="name" placeholder="Rajesh Patel" required/>
                </div>
                <div class="form-group">
                  <label class="form-label" for="dist-phone">Phone Number * <small style="color:var(--color-accent)">(This will be your Login ID)</small></label>
                  <input class="form-input" type="tel" id="dist-phone" name="phone" placeholder="+91 98765 43210" required/>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="dist-email">Email Address *</label>
                  <input class="form-input" type="email" id="dist-email" name="email" placeholder="rajesh@example.com" required/>
                </div>
                <div class="form-group">
                  <label class="form-label" for="dist-company">Company / Firm Name *</label>
                  <input class="form-input" type="text" id="dist-company" name="company" placeholder="Patel Agro Traders" required/>
                </div>
              </div>

              <div class="form-section-label" style="margin-top:var(--space-4)">Business Details</div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="dist-location">City / State *</label>
                  <input class="form-input" type="text" id="dist-location" name="location" placeholder="Ahmedabad, Gujarat" required/>
                </div>
                <div class="form-group">
                  <label class="form-label" for="dist-product">Product Interest *</label>
                  <select class="form-input" id="dist-product" name="product" required>
                    <option value="">— Select Product —</option>
                    <option>Triethyl Citrate (TEC)</option>
                    <option>Diethyl Phthalate (DEP)</option>
                    <option>F.S. Calcival</option>
                    <option>All Products</option>
                  </select>
                </div>
              </div>
              <div class="form-group full">
                <label class="form-label" for="dist-quantity">Expected Monthly Quantity (Litres / Units) *</label>
                <input class="form-input" type="text" id="dist-quantity" name="quantity" placeholder="e.g. 500 Litres/month" required/>
              </div>

              <button type="submit" class="btn btn-primary" style="width:100%;padding:var(--space-4);font-size:var(--text-base);margin-top:var(--space-2)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                Submit Registration Request
              </button>
              <p style="text-align:center;font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--space-3)">
                Already approved? <a href="/buy?tab=login" style="color:var(--color-accent);font-weight:600">Login here →</a>
              </p>
            </form>
          </div>
        </div>
        <% } %>
      </div>

      <!-- ══════════════════════════════════════
           TAB 2 — LOGIN
      ══════════════════════════════════════ -->
      <% } else { %>
      <div class="buy-panel" role="tabpanel">
        <div class="buy-login-wrap">
          <div class="buy-login-card">
            <!-- Icon -->
            <div class="buy-login-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            </div>
            <h2>Distributor Login</h2>
            <p>Enter your approved credentials to access the distributor portal.</p>

            <!-- Error messages -->
            <% if(error === 'invalid_credentials'){ %>
            <div class="dist-alert dist-alert-error">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Invalid phone number or password. Please check your credentials.
            </div>
            <% } %>
            <% if(error === 'pending'){ %>
            <div class="dist-alert dist-alert-warning">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Your application is still <strong>pending admin approval</strong>. We'll notify you once approved.
            </div>
            <% } %>
            <% if(error === 'rejected'){ %>
            <div class="dist-alert dist-alert-error">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Your application was not approved. Please <a href="/contact">contact us</a> for more information.
            </div>
            <% } %>

            <form action="/buy/login" method="POST" id="dist-login-form" style="margin-top:var(--space-5)">
              <div class="form-group">
                <label class="form-label" for="login-phone">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  Phone Number (Login ID)
                </label>
                <input class="form-input" type="tel" id="login-phone" name="phone" placeholder="+91 98765 43210" required style="font-size:var(--text-base);letter-spacing:.04em"/>
              </div>
              <div class="form-group" style="position:relative">
                <label class="form-label" for="login-password">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                  Password
                </label>
                <input class="form-input" type="password" id="login-password" name="password" placeholder="••••••••" required style="font-size:var(--text-base);letter-spacing:.15em"/>
                <button type="button" class="pwd-toggle" id="pwd-toggle" aria-label="Show/hide password">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </div>
              <button type="submit" class="btn btn-primary" style="width:100%;padding:var(--space-4);font-size:var(--text-base);margin-top:var(--space-2)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                Login to Portal
              </button>
            </form>

            <div class="buy-login-divider"><span>Don't have an account?</span></div>
            <a href="/buy?tab=register" class="btn btn-outline" style="width:100%;justify-content:center;margin-top:var(--space-3)">Register as Distributor</a>
            <p style="text-align:center;font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--space-4)">
              Need help? <a href="/contact" style="color:var(--color-accent)">Contact support →</a>
            </p>
          </div>

          <!-- Right side info -->
          <div class="buy-login-info">
            <h3>Distributor Benefits</h3>
            <% [
              {icon:'📦',title:'Bulk Order Access',desc:'Place large quantity orders with negotiated pricing.'},
              {icon:'🚀',title:'Priority Processing',desc:'Your orders get processed before retail customers.'},
              {icon:'📊',title:'Sales Analytics',desc:'Track your order history and monthly volumes.'},
              {icon:'🤝',title:'Dedicated Support',desc:'Direct line to your account manager.'}
            ].forEach(function(b){ %>
            <div class="login-benefit">
              <span class="login-benefit-icon"><%= b.icon %></span>
              <div>
                <strong><%= b.title %></strong>
                <p><%= b.desc %></p>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
      <% } %>

    </div><!-- /buy-portal-wrap -->
  </div>
</section>

<script>
// Password toggle
document.getElementById('pwd-toggle')?.addEventListener('click', function(){
  const inp = document.getElementById('login-password');
  inp.type = inp.type === 'password' ? 'text' : 'password';
});
</script>

<%- include('partials/footer') %>
