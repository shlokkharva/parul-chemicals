<%- include('partials/header') %>

<!-- PAGE HERO -->
<div style="background:var(--grad-hero);padding:calc(var(--header-h) + var(--space-16)) 0 var(--space-16);position:relative;overflow:hidden">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="mol-nodes" aria-hidden="true">
    <div class="mol-node"></div><div class="mol-node large"></div><div class="mol-node"></div>
  </div>
  <div class="container" style="position:relative;z-index:2;text-align:center">
    <span class="section-label" style="justify-content:center">Our Products</span>
    <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3.2rem);font-weight:800;color:#F1F5FF;letter-spacing:-.02em;line-height:1.15;margin-bottom:var(--space-5)">
      Precision-Engineered<br/>Chemical Solutions
    </h1>
    <p style="font-size:var(--text-lg);color:var(--color-text-on-dark-muted);max-width:560px;margin:0 auto">
      Every compound is synthesized to the highest pharmacopeial standards, backed by rigorous quality control.
    </p>
  </div>
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="#ffffff"/></svg>
  </div>
</div>

<!-- PRODUCTS GRID -->
<section class="section">
  <div class="container">
    <div class="products-grid">
      <% products.forEach(function(p, i){ %>
      <article class="product-card reveal reveal-delay-<%= i+1 %>">
        <div class="card-badge">
          <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" fill="currentColor"/></svg>
          <%= p.badge %>
        </div>
        <div class="card-mol-svg">
          <!-- Molecular SVG placeholder -->
          <svg width="120" height="120" viewBox="0 0 120 120" fill="none" aria-label="<%= p.abbr %> molecular structure">
            <circle cx="60" cy="60" r="<%= i===1?8:12 %>" fill="<%= i===1?'#1A2B4C':'#00A86B' %>" opacity=".9"/>
            <circle cx="25" cy="35" r="8" fill="<%= i===1?'#00A86B':'#1A2B4C' %>" opacity=".8"/>
            <circle cx="95" cy="35" r="8" fill="<%= i===1?'#00A86B':'#1A2B4C' %>" opacity=".8"/>
            <circle cx="25" cy="85" r="8" fill="<%= i===1?'#00A86B':'#1A2B4C' %>" opacity=".8"/>
            <circle cx="95" cy="85" r="8" fill="<%= i===1?'#00A86B':'#1A2B4C' %>" opacity=".8"/>
            <circle cx="8"  cy="20" r="5" fill="#00C47D" opacity=".5"/>
            <circle cx="112" cy="20" r="5" fill="#00C47D" opacity=".5"/>
            <circle cx="8"  cy="100" r="5" fill="#00C47D" opacity=".5"/>
            <circle cx="112" cy="100" r="5" fill="#00C47D" opacity=".5"/>
            <line x1="60" y1="60" x2="25" y2="35" stroke="#00A86B" stroke-width="2" opacity=".6"/>
            <line x1="60" y1="60" x2="95" y2="35" stroke="#00A86B" stroke-width="2" opacity=".6"/>
            <line x1="60" y1="60" x2="25" y2="85" stroke="#00A86B" stroke-width="2" opacity=".6"/>
            <line x1="60" y1="60" x2="95" y2="85" stroke="#00A86B" stroke-width="2" opacity=".6"/>
            <text x="54" y="65" font-size="9" fill="white" font-weight="700" font-family="Inter,sans-serif"><%= p.abbr.substring(0,3) %></text>
          </svg>
        </div>
        <div class="product-name"><%= p.name %></div>
        <div class="product-abbr"><%= p.abbr %></div>
        <% if(p.cas){ %><div class="product-cas">CAS No. <strong><%= p.cas %></strong></div><% } %>
        <% if(p.formula){ %><div class="product-cas">Formula: <strong><%= p.formula %></strong></div><% } %>
        <% if(!p.cas){ %>
          <div class="product-cas">Type: <strong>Multi-Vitamin &amp; Calcium</strong></div>
          <div class="product-cas">For: <strong>Cattle &middot; Buffalo &middot; Goats</strong></div>
        <% } %>
        <p class="product-desc"><%= p.desc %></p>
        <div class="product-footer">
          <span class="product-app"><%= p.apps %></span>
          <% if(p.id === 'fscalcival'){ %>
            <a href="/fscalcival" class="btn btn-outline">Buy Now</a>
          <% } else { %>
            <a href="/contact?product=<%= p.abbr %>" class="btn btn-outline">Inquire</a>
          <% } %>
        </div>
      </article>
      <% }) %>
    </div>
  </div>
</section>

<!-- APPLICATIONS TABLE -->
<section class="section section-alt">
  <div class="container">
    <div class="section-header centered reveal">
      <span class="section-label">Application Areas</span>
      <h2 class="section-title">Where Our Products Excel</h2>
    </div>
    <div style="overflow-x:auto">
      <table style="width:100%;border-collapse:collapse;font-size:var(--text-sm)">
        <thead>
          <tr style="background:var(--color-primary);color:#fff">
            <th style="padding:var(--space-4) var(--space-5);text-align:left;border-radius:var(--radius-lg) 0 0 0">Application</th>
            <% products.forEach(function(p){ %>
              <th style="padding:var(--space-4) var(--space-5);text-align:center"><%= p.abbr %></th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% [
            'Pharmaceutical Coatings','Food &amp; Beverage','Personal Care / Cosmetics',
            'Adhesives &amp; Sealants','Inks, Paints &amp; Coatings','Plastics &amp; Polymers','Animal Nutrition'
          ].forEach(function(app, i){ %>
          <tr style="background:<%= i%2===0 ? '#fff' : 'var(--color-surface)' %>;border-bottom:1px solid var(--color-border)">
            <td style="padding:var(--space-3) var(--space-5);font-weight:500;color:var(--color-text)"><%- app %></td>
            <td style="padding:var(--space-3) var(--space-5);text-align:center"><%= ['✅','✅','✅','✅','✅','✅','❌'][i] %></td>
            <td style="padding:var(--space-3) var(--space-5);text-align:center"><%= ['❌','❌','❌','❌','❌','❌','✅'][i] %></td>
            <td style="padding:var(--space-3) var(--space-5);text-align:center"><%= ['✅','❌','✅','✅','✅','✅','❌'][i] %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- BECOME A DISTRIBUTOR BANNER -->
<div class="dist-cta-banner">
  <div class="container">
    <div class="dist-cta-inner">
      <div class="dist-cta-left">
        <div class="dist-cta-badge">🤝 Partner With Us</div>
        <h2 class="dist-cta-title">Become an Authorized Distributor</h2>
        <p class="dist-cta-desc">Sell Parul Chemicals' high-purity plasticizers and supplements. Apply in minutes — get approval within 24–48 hours.</p>
        <div class="dist-cta-perks">
          <span class="dist-cta-perk">✅ Wholesale Pricing</span>
          <span class="dist-cta-perk">✅ Priority Delivery</span>
          <span class="dist-cta-perk">✅ Dedicated Manager</span>
        </div>
      </div>
      <div class="dist-cta-right">
        <a href="/buy?tab=register" class="btn dist-cta-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          Become a Distributor
        </a>

      </div>
    </div>
  </div>
</div>

<!-- MSDS CTA -->
<section class="section" style="padding:var(--space-12) 0">
  <div class="container" style="text-align:center">
    <h3 class="reveal" style="font-size:var(--text-2xl);font-weight:800;color:var(--color-primary);margin-bottom:var(--space-3)">Download Safety Data Sheets</h3>
    <p class="reveal" style="color:var(--color-text-muted);margin-bottom:var(--space-6)">Full MSDS available for all chemical products.</p>
    <div class="reveal" style="display:flex;justify-content:center;gap:var(--space-4);flex-wrap:wrap">
      <a href="https://parulchemicals.com/wp-content/uploads/2024/02/parul_chemical_msds.pdf" target="_blank" class="btn btn-primary btn-lg">Download TEC MSDS</a>
      <a href="https://parulchemicals.com/wp-content/uploads/2024/02/MSDS-DEP.pdf" target="_blank" class="btn btn-outline btn-lg">Download DEP MSDS</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
