<%- include('partials/header') %>

<!-- HERO -->
<section class="hero" id="home" aria-label="Hero">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="mol-nodes" aria-hidden="true">
    <div class="mol-node"></div><div class="mol-node large"></div>
    <div class="mol-node"></div><div class="mol-node xlarge"></div>
    <div class="mol-node"></div><div class="mol-node large"></div>
  </div>
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-pill">
        <div class="hero-pill-dot"></div>
        Global Innovative Solutions &middot; Pharmaceutical &amp; Agrochemicals
      </div>
      <h1 class="hero-headline">Enriching Life Through<br/><em>Plasticizer Innovation</em></h1>
      <p class="hero-subline">Precision-engineered plasticizers and specialty chemicals trusted by leading pharmaceutical, agrochemical, food and nutrition industries worldwide.</p>
      <div class="hero-actions">
        <a href="/buy?tab=register" class="btn btn-primary btn-lg hero-dist-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          Become a Distributor
        </a>
        <a href="/products" class="btn btn-outline-light btn-lg">
          Explore Products
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <div class="hero-mol-card">
        <div class="mol-svg-wrap">
          <svg width="240" height="160" viewBox="0 0 240 160" fill="none">
            <circle cx="120" cy="80" r="14" fill="#00A86B" opacity=".9"/>
            <circle cx="60" cy="50"  r="10" fill="#1A2B4C" opacity=".8"/>
            <circle cx="180" cy="50" r="10" fill="#1A2B4C" opacity=".8"/>
            <circle cx="60" cy="110" r="10" fill="#1A2B4C" opacity=".8"/>
            <circle cx="180" cy="110" r="10" fill="#1A2B4C" opacity=".8"/>
            <circle cx="20" cy="35"  r="7" fill="#00C47D" opacity=".6"/>
            <circle cx="220" cy="35" r="7" fill="#00C47D" opacity=".6"/>
            <circle cx="20" cy="125" r="7" fill="#00C47D" opacity=".6"/>
            <circle cx="220" cy="125" r="7" fill="#00C47D" opacity=".6"/>
            <line x1="120" y1="80" x2="60" y2="50"  stroke="#00A86B" stroke-width="2.5" opacity=".6"/>
            <line x1="120" y1="80" x2="180" y2="50" stroke="#00A86B" stroke-width="2.5" opacity=".6"/>
            <line x1="120" y1="80" x2="60" y2="110"  stroke="#00A86B" stroke-width="2.5" opacity=".6"/>
            <line x1="120" y1="80" x2="180" y2="110" stroke="#00A86B" stroke-width="2.5" opacity=".6"/>
            <line x1="60" y1="50"  x2="20" y2="35"   stroke="#1A2B4C" stroke-width="1.5" opacity=".4"/>
            <line x1="180" y1="50" x2="220" y2="35"  stroke="#1A2B4C" stroke-width="1.5" opacity=".4"/>
            <line x1="60" y1="110" x2="20" y2="125"  stroke="#1A2B4C" stroke-width="1.5" opacity=".4"/>
            <line x1="180" y1="110" x2="220" y2="125" stroke="#1A2B4C" stroke-width="1.5" opacity=".4"/>
            <text x="112" y="85" font-size="10" fill="white" font-weight="700" font-family="Inter,sans-serif">C</text>
          </svg>
        </div>
        <div style="text-align:center;margin-bottom:8px">
          <span style="font-size:.6rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#00A86B">TRIETHYL CITRATE (TEC)</span>
        </div>
        <div style="text-align:center;font-size:.7rem;color:rgba(241,245,255,.5);margin-bottom:16px">CAS No. 77-93-0 &middot; Pharmaceutical Grade</div>
        <div class="hero-stat-row">
          <div class="hero-stat"><div class="hero-stat-val">99<span>.9%</span></div><div class="hero-stat-label">Purity</div></div>
          <div class="hero-stat" style="border-left:1px solid rgba(255,255,255,.08)"><div class="hero-stat-val">25<span>+</span></div><div class="hero-stat-label">Countries</div></div>
          <div class="hero-stat" style="border-left:1px solid rgba(255,255,255,.08)"><div class="hero-stat-val">GMP</div><div class="hero-stat-label">Certified</div></div>
        </div>
      </div>
    </div>
  </div>
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="#ffffff"/></svg>
  </div>
</section>

<!-- TRUST STRIP -->
<div class="trust-strip">
  <div class="container">
    <div class="trust-inner">
      <span class="trust-label">Trusted across</span>
      <div class="trust-logos">
        <span class="trust-logo-item">PHARMACEUTICAL</span>
        <span class="trust-logo-item">AGROCHEMICAL</span>
        <span class="trust-logo-item">FOOD &amp; NUTRITION</span>
        <span class="trust-logo-item">COSMETICS</span>
        <span class="trust-logo-item">POLYMER SCIENCE</span>
      </div>
    </div>
  </div>
</div>

<!-- STATS STRIP -->
<div class="stats-strip">
  <div class="container">
    <div class="stats-inner">
      <div class="stat-item reveal"><div class="stat-val">25<span>+</span></div><div class="stat-lbl">Countries Served</div><div class="stat-divider"></div></div>
      <div class="stat-item reveal reveal-delay-1"><div class="stat-val">99<span>.9%</span></div><div class="stat-lbl">Average Purity</div><div class="stat-divider"></div></div>
      <div class="stat-item reveal reveal-delay-2"><div class="stat-val">15<span>+</span></div><div class="stat-lbl">Years of Excellence</div><div class="stat-divider"></div></div>
      <div class="stat-item reveal reveal-delay-3"><div class="stat-val">100<span>%</span></div><div class="stat-lbl">GMP Compliance</div><div class="stat-divider"></div></div>
    </div>
  </div>
</div>

<!-- DISTRIBUTOR CTA BANNER -->
<div class="dist-cta-banner">
  <div class="container">
    <div class="dist-cta-inner">
      <div class="dist-cta-left">
        <div class="dist-cta-badge">🤝 Partner With Us</div>
        <h2 class="dist-cta-title">Become an Authorized Distributor</h2>
        <p class="dist-cta-desc">Join our growing network of trusted distributors across India. Get exclusive wholesale pricing, priority support and an authorized distributor certificate.</p>
        <div class="dist-cta-perks">
          <span class="dist-cta-perk">✅ Wholesale Pricing</span>
          <span class="dist-cta-perk">✅ Priority Delivery</span>
          <span class="dist-cta-perk">✅ Dedicated Manager</span>
          <span class="dist-cta-perk">✅ Free TDS &amp; COA</span>
        </div>
      </div>
      <div class="dist-cta-right">
        <a href="/buy?tab=register" class="btn dist-cta-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          Become a Distributor
        </a>

      </div>
    </div>
  </div>
</div>

<!-- QUICK LINKS to all pages -->
<section class="section">
  <div class="container">
    <div class="section-header centered reveal">
      <span class="section-label">Explore</span>
      <h2 class="section-title">Everything Parul Chemicals</h2>
      <p class="section-desc centered">Navigate to any section to learn more about our products, certifications and expertise.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-6)">
      <% [
        {href:'/products',       icon:'⚗️',  title:'Our Products',       desc:'TEC, DEP and F.S. Calcival — precision-engineered compounds with certified purity.'},
        {href:'/fscalcival',     icon:'🐄',  title:'Buy F.S. Calcival',  desc:'Premium livestock calcium supplement. Multiple pack sizes, brochures in 4 languages.'},
        {href:'/certifications', icon:'🏅',  title:'Certifications',     desc:'GMP, WHO-GMP compliance with downloadable MSDS and global regulatory declarations.'},
        {href:'/why-us',         icon:'💡',  title:'Why Choose Us',      desc:'Innovation, quality and deep industry expertise across pharma, agro and nutrition.'},
        {href:'/contact',        icon:'📬',  title:'Contact Us',         desc:'Reach our team for TDS requests, quotes, custom synthesis and regulatory dossiers.'},
        {href:'https://parulchemicals.in/declarations/', icon:'📋', title:'Declarations', desc:'View all official product declarations and regulatory compliance documents.'}
      ].forEach(function(card){ %>
        <a href="<%= card.href %>" class="bento-card reveal" style="display:block;text-decoration:none;padding:var(--space-8)" target="<%= card.href.startsWith('http') ? '_blank' : '_self' %>">
          <div style="font-size:2.2rem;margin-bottom:var(--space-4)"><%= card.icon %></div>
          <h3 style="margin-bottom:var(--space-3)"><%= card.title %></h3>
          <p style="margin:0"><%= card.desc %></p>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
