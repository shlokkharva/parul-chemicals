<%- include('partials/header') %>

<!-- PAGE HERO -->
<div style="background:linear-gradient(135deg,#0F2E1A 0%,#1A4C2E 50%,#103320 100%);padding:calc(var(--header-h) + var(--space-16)) 0 var(--space-16);position:relative;overflow:hidden">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="container" style="position:relative;z-index:2;text-align:center">
    <div class="hero-pill" style="justify-content:center;width:fit-content;margin:0 auto var(--space-5)">
      <div class="hero-pill-dot"></div>Premium Livestock Supplement · Multi-Vitamin &amp; Calcium
    </div>
    <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3.2rem);font-weight:800;color:#F1F5FF;letter-spacing:-.02em;line-height:1.15;margin-bottom:var(--space-5)">
      F.S. Calcival<br/><em style="background:linear-gradient(135deg,#00C47D,#00E896);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">Unlocking the Energy of Calcium</em>
    </h1>
    <p style="font-size:var(--text-lg);color:var(--color-text-on-dark-muted);max-width:600px;margin:0 auto">
      Not just calcium — a multi-vitamin and calcium formulation that enhances energy, bolsters immunity and significantly increases milk production in dairy cattle, buffalo and goats.
    </p>
  </div>
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="#F8FAFC"/></svg>
  </div>
</div>

<!-- BENEFITS -->
<section class="section section-alt">
  <div class="container">
    <div class="section-header centered reveal">
      <span class="section-label">Scientifically Proven</span>
      <h2 class="section-title">Why Farmers Choose F.S. Calcival</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-6)">
      <% [
        {icon:'🐄',title:'Increased Milk Production',desc:'Rise from 5.5L to 6.5L in 10–15 days. Extra 30 litres/month = ₹1,020+ additional profit per cow.'},
        {icon:'⚡',title:'Enhanced Energy & Immunity',desc:'Multi-vitamin and herbal mineral complex improves overall health and prevents adverse effects in cattle.'},
        {icon:'📈',title:'Improved SNF Levels',desc:'Meets dairy standards even in summer — up to ₹4,488 additional profit per month from quality bonuses.'}
      ].forEach(function(b,i){ %>
      <div class="bento-card reveal reveal-delay-<%= i+1 %>" style="text-align:center">
        <div style="font-size:2.5rem;margin-bottom:var(--space-4)"><%= b.icon %></div>
        <h3><%= b.title %></h3>
        <p><%= b.desc %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- PACK SIZES / BUY -->
<section class="section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Available Pack Sizes</span>
      <h2 class="section-title">Choose Your Packaging</h2>
      <p class="section-desc">Order by contacting us directly — our team will arrange delivery to your location.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:var(--space-5);margin-bottom:var(--space-12)">
      <% packSizes.forEach(function(pack,i){ %>
      <div class="product-card reveal reveal-delay-<%= i+1 %>" style="text-align:center;padding:var(--space-6)">
        <div style="font-size:2.5rem;margin-bottom:var(--space-3)"><%= pack.icon %></div>
        <div class="product-name" style="font-size:var(--text-lg)"><%= pack.size %></div>
        <div class="product-abbr" style="font-size:var(--text-xs)"><%= pack.pack %></div>
        <a href="/contact?product=FS+CALCIVAL+(<%= pack.size %>)" class="btn btn-primary" style="margin-top:var(--space-4);width:100%;justify-content:center">Order Now</a>
      </div>
      <% }) %>
    </div>

    <!-- DOSAGE -->
    <div class="section-header reveal">
      <span class="section-label">Usage Guidelines</span>
      <h2 class="section-title">Dosage Instructions</h2>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-6);margin-bottom:var(--space-12)">
      <% [
        {title:'For Progenated Animals (Post-Delivery)',steps:['Give 50ml doses morning & evening','Mix with cattle feed','Start from 1 week after delivery','Continue until 5 months','Consult a doctor after 5 months']},
        {title:'For Pregnant Animals',steps:['Feed 20–40ml of F.S. Calcival daily','As per your local animal doctor\'s advice','Boosts overall health','Improves calf health','Regulates heat cycle']}
      ].forEach(function(d,i){ %>
      <div class="bento-card reveal reveal-delay-<%= i+1 %>">
        <div class="bento-icon-wrap"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00A86B" stroke-width="2"><path d="M9 3h6v6l4 9H5L9 9V3z"/><line x1="9" y1="3" x2="15" y2="3"/></svg></div>
        <h3><%= d.title %></h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:var(--space-2);margin-top:var(--space-3)">
          <% d.steps.forEach(function(s){ %>
          <li style="display:flex;align-items:center;gap:var(--space-3);font-size:var(--text-sm);color:var(--color-text-muted)">
            <span style="width:20px;height:20px;background:var(--color-accent-muted);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#00A86B" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <%= s %>
          </li>
          <% }) %>
        </ul>
      </div>
      <% }) %>
    </div>

    <!-- BROCHURES -->
    <div class="section-header centered reveal">
      <span class="section-label">Downloads</span>
      <h2 class="section-title">Product Brochures</h2>
      <p class="section-desc centered">Available in 4 languages for your convenience.</p>
    </div>
    <div style="display:flex;justify-content:center;gap:var(--space-4);flex-wrap:wrap;margin-top:var(--space-6)" class="reveal">
      <% brochures.forEach(function(b){ %>
      <a href="<%= b.url %>" target="_blank" class="btn btn-outline btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        <%= b.lang %> Brochure
      </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA -->
<div class="stats-strip" style="padding:var(--space-16) 0;text-align:center">
  <div class="container">
    <h3 style="font-size:var(--text-3xl);font-weight:800;color:#fff;margin-bottom:var(--space-4)">Ready to boost your livestock's productivity?</h3>
    <p style="color:var(--color-text-on-dark-muted);margin-bottom:var(--space-8);font-size:var(--text-lg)">Contact our team to place an order or get expert advice.</p>
    <a href="/contact?product=FS+CALCIVAL" class="btn btn-primary btn-lg">Contact &amp; Order Now</a>
  </div>
</div>

<%- include('partials/footer') %>
