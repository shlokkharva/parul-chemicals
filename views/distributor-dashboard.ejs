<%- include('partials/header') %>

<!-- DASHBOARD HEADER -->
<div style="background:linear-gradient(135deg,#0A2818 0%,#1A4C2E 60%,#0F2E1A 100%);padding:calc(var(--header-h) + var(--space-10)) 0 var(--space-10);position:relative;overflow:hidden">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="container" style="position:relative;z-index:2">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:var(--space-5)">
      <div>
        <div style="display:inline-flex;align-items:center;gap:var(--space-2);background:rgba(0,168,107,.15);border:1px solid rgba(0,168,107,.3);border-radius:var(--radius-full);padding:var(--space-1) var(--space-4);margin-bottom:var(--space-4)">
          <span style="width:8px;height:8px;background:#00A86B;border-radius:50%;animation:pulse 2s infinite"></span>
          <span style="font-size:var(--text-xs);font-weight:700;color:#00A86B;letter-spacing:.08em;text-transform:uppercase">Authorized Distributor</span>
        </div>
        <h1 style="font-family:var(--font-serif);font-size:clamp(1.6rem,3vw,2.4rem);font-weight:800;color:#F1F5FF;letter-spacing:-.02em;margin:0">
          Welcome, <%= dist.name %>!
        </h1>
        <p style="color:rgba(241,245,255,.55);margin-top:var(--space-2)"><%= dist.company %> &bull; <%= dist.location %></p>
      </div>
      <div class="dist-id-card">
        <div class="dist-id-label">Your Distributor ID</div>
        <div class="dist-id-value"><%= dist.phone %></div>
        <div class="dist-id-badge">Active &bull; <%= dist.product %></div>
      </div>
    </div>
  </div>
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none"><path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="#F8FAFC"/></svg>
  </div>
</div>

<section style="padding:var(--space-10) 0 var(--space-16);background:var(--color-surface)">
  <div class="container">

    <!-- QUICK STATS -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-5);margin-bottom:var(--space-10)">
      <% [
        {icon:'📦', val:'0',    lbl:'Orders Placed',  sub:'This month'},
        {icon:'✅', val:'0',    lbl:'Delivered',       sub:'All time'},
        {icon:'⏳', val:'0',    lbl:'Pending Delivery',sub:'In transit'},
        {icon:'💰', val:'₹0',   lbl:'Total Value',     sub:'All orders'}
      ].forEach(function(s){ %>
      <div class="dist-stat-card">
        <span style="font-size:1.8rem;"><%= s.icon %></span>
        <div class="dist-stat-val"><%= s.val %></div>
        <div class="dist-stat-lbl"><%= s.lbl %></div>
        <div class="dist-stat-sub"><%= s.sub %></div>
      </div>
      <% }) %>
    </div>

    <div style="display:grid;grid-template-columns:1fr 380px;gap:var(--space-8);align-items:start">

      <!-- LEFT: Products to Order -->
      <div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-5)">
          <h2 style="font-size:var(--text-xl);font-weight:800;color:var(--color-primary)">Available Products</h2>
          <span class="status-badge status-approved">Wholesale Pricing Active</span>
        </div>

        <div style="display:flex;flex-direction:column;gap:var(--space-4)">
          <% products.forEach(function(p){ %>
          <div class="dist-product-row">
            <div class="dist-product-info">
              <div style="font-weight:700;color:var(--color-primary);font-size:var(--text-base)"><%= p.name %></div>
              <div style="font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--space-1)"><%= p.badge %> &bull; <%= p.apps %></div>
              <div style="font-size:var(--text-xs);color:var(--color-text-muted)"><%= p.desc.substring(0,90) %>…</div>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:var(--space-2);flex-shrink:0">
              <% if(p.cas){ %><span class="mono-chip" style="font-size:var(--text-xs)">CAS <%= p.cas %></span><% } %>
              <button onclick="openOrder('<%= p.name %>', '<%= p.abbr %>')" class="btn btn-primary" style="padding:var(--space-2) var(--space-4);font-size:var(--text-sm)">
                Place Order →
              </button>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- RIGHT: Account Info + Order Form -->
      <div>
        <!-- Account Info -->
        <div class="bento-card" style="margin-bottom:var(--space-5)">
          <h3 style="margin-bottom:var(--space-4)">Account Details</h3>
          <% [
            {lbl:'Full Name',    val: dist.name},
            {lbl:'Phone / ID',   val: dist.phone},
            {lbl:'Email',        val: dist.email},
            {lbl:'Company',      val: dist.company},
            {lbl:'Location',     val: dist.location},
            {lbl:'Product',      val: dist.product},
            {lbl:'Quantity/Mo.', val: dist.quantity},
            {lbl:'Approved On',  val: new Date(dist.approvedAt).toLocaleDateString('en-IN')}
          ].forEach(function(f){ %>
          <div style="display:flex;justify-content:space-between;align-items:center;padding:var(--space-2) 0;border-bottom:1px solid var(--color-border);font-size:var(--text-sm)">
            <span style="color:var(--color-text-muted);font-weight:500"><%= f.lbl %></span>
            <span style="font-weight:600;color:var(--color-primary);max-width:55%;text-align:right;word-break:break-all"><%= f.val %></span>
          </div>
          <% }) %>
          <a href="/contact?product=<%= dist.product %>" class="btn btn-outline" style="width:100%;justify-content:center;margin-top:var(--space-4)">Contact Support</a>
        </div>

        <!-- Order Request Form -->
        <div class="bento-card" id="order-form-card" style="display:none">
          <h3 id="order-form-title">Place Order</h3>
          <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)">Submit your order request and our team will contact you within 12 hours.</p>
          <form action="/contact" method="POST">
            <input type="hidden" name="name" value="<%= dist.name %>"/>
            <input type="hidden" name="email" value="<%= dist.email %>"/>
            <input type="hidden" name="company" value="<%= dist.company %> (Distributor ID: <%= dist.phone %>)"/>
            <div class="form-group">
              <label class="form-label" for="order-product">Product</label>
              <input class="form-input" type="text" id="order-product" name="product" readonly/>
            </div>
            <div class="form-group">
              <label class="form-label" for="order-qty">Quantity Required *</label>
              <input class="form-input" type="text" id="order-qty" name="message" placeholder="e.g. 200 Litres" required/>
            </div>
            <div style="display:flex;gap:var(--space-3);margin-top:var(--space-2)">
              <button type="submit" class="btn btn-primary" style="flex:1">Submit Order</button>
              <button type="button" onclick="closeOrder()" class="btn btn-outline">Cancel</button>
            </div>
          </form>
        </div>

      </div>
    </div>

    <!-- Logout -->
    <div style="text-align:center;margin-top:var(--space-12)">
      <a href="/buy?tab=login" class="btn btn-outline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Logout
      </a>
    </div>

  </div>
</section>

<script>
function openOrder(product, abbr){
  document.getElementById('order-product').value = product;
  document.getElementById('order-form-title').textContent = 'Place Order — ' + abbr;
  document.getElementById('order-form-card').style.display = 'block';
  document.getElementById('order-form-card').scrollIntoView({ behavior:'smooth', block:'center' });
}
function closeOrder(){
  document.getElementById('order-form-card').style.display = 'none';
}
</script>

<%- include('partials/footer') %>
